# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional SMTP settings for custom email sending
# If not supplied, emails are sent via dynamic test accounts (Ethereal Mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Floating Drapes Web" <noreply@floatingdrapes.com>
SMTP_TO=

# Server Admin Authentication Credentials & Secrets (Stored exclusively on Backend)
ADMIN_EMAIL=boopathiakasanjay@gmail.com
ADMIN_PASSWORD=admin123
ADMIN_SECRET_KEY=fd_master_secret_hash_salt_2026

